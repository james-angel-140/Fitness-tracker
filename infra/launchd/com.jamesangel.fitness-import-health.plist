<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.jamesangel.fitness-import-health</string>

  <key>ProgramArguments</key>
  <array>
    <string>/opt/homebrew/bin/node</string>
    <string>/Users/jamesangel/Documents/Development/Fitness-tracker/node_modules/.bin/tsx</string>
    <string>/Users/jamesangel/Documents/Development/Fitness-tracker/cli/import-health-export.ts</string>
