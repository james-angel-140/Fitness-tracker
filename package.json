{
  "name": "fitness-tracker",
  "version": "1.0.0",
  "description": "Personal fitness data store — structured JSON logs with TypeScript schemas",
  "private": true,
  "workspaces": [
    "dashboard"
  ],
  "scripts": {
    "score": "tsx cli/calculate-score.ts",
    "context": "tsx cli/context.ts",
    "upcoming": "tsx cli/upcoming.ts",
    "plan": "tsx cli/plan.ts",
    "preload-sessions": "tsx cli/preload-sessions.ts",
    "log:nutrition": "tsx cli/log-nutrition.ts",
    "import:health": "tsx cli/import-health-export.ts",
    "typecheck": "tsc --noEmit",
    "dashboard": "npm -w dashboard run dev",
    "dashboard:build": "npm -w dashboard run build",
    "deploy": "VITE_BASE=/Fitness-tracker/ npm -w dashboard run build && npm -w dashboard run deploy",
    "server": "tsx server/index.ts",
    "server:build": "npm run dashboard:build && echo '✓ Build complete — restart server to serve new files'"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.88.0",
    "@types/node": "^25.6.0",
    "dotenv": "^17.4.1",
    "tsx": "^4.19.0",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "@types/express": "^5.0.6",
    "express": "^5.2.1"
  }
}
